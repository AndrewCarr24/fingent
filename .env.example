# Copy to .env and fill in real values. .env is gitignored.

# === Required ================================================================

# DeepSeek API key — used by the orchestrator (when ORCHESTRATOR_PROVIDER=deepseek),
# the auto-query helper, and the smart-α retrieval call.
DEEPSEEK_API_KEY=sk-...

# AWS credentials — required for Bedrock embeddings (Titan v2) used at KB build
# time AND retrieval time. Also required if ORCHESTRATOR_PROVIDER=bedrock.
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1


# === Provider selection ======================================================

# "deepseek" (cheap, default) or "bedrock" (Anthropic Claude via Bedrock).
# Router and judge always run on Bedrock Haiku regardless of this setting.
ORCHESTRATOR_PROVIDER=deepseek

# DeepSeek model for the orchestrator + smart-α + auto-query.
# v4-flash is the cheapest reasoning-capable option.
DEEPSEEK_MODEL_ID=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Bedrock model for the orchestrator (used when ORCHESTRATOR_PROVIDER=bedrock).
ORCHESTRATOR_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Bedrock model for the router (intent classifier). Always Bedrock.
ROUTER_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0


# === Retrieval knobs (optional) ==============================================

# Set "true" to enable hybrid BM25 + semantic retrieval (recommended; default).
HYBRID_BM25=true

# RRF α (BM25 weight, 0..1). "smart" lets DeepSeek pick per-question (default);
# numeric value forces a fixed α (e.g. 0.4 — the FinanceBench-tuned static value).
RRF_ALPHA=smart

# Top-k candidates per retriever before RRF fusion.
RETRIEVAL_TOP_K=200


# === Observability (optional) ================================================

# LangSmith tracing — leave LANGSMITH_TRACING unset or "false" to disable.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=fingent
